# Production Secrets (REPLACE THESE IN PRODUCTION)
# Copy this file to production_vars.yml and fill in the values.
# production_vars.yml is ignored by git.

platform_secrets:
  authentik_secret_key: "CHANGE_ME"
  authentik_postgres_password: "CHANGE_ME"
  authentik_bootstrap_email: "admin@thekeepstudios.com"
  authentik_bootstrap_password: "CHANGE_ME"
  leantime_db_root_password: "CHANGE_ME"
  leantime_db_password: "CHANGE_ME"
  wisemapping_postgres_password: "CHANGE_ME"
  wisemapping_jwt_secret: "CHANGE_ME"
  wisemapping_oauth_token_secret: "CHANGE_ME"
  cloudflare_tunnel_token: "CHANGE_ME"
  grafana_admin_user: "admin"
  grafana_admin_password: "CHANGE_ME"
  # Optional: defaults to grafana_admin_user/grafana_admin_password when omitted.
  monitoring_basic_auth_user: "admin"
  monitoring_basic_auth_password: "CHANGE_ME"

# Optional: enable these only when gitops_repo_private is true.
# gitops_repo_ssh_private_key_path: "/path/to/argocd-readonly-key"
# gitops_repo_ssh_private_key: |
#   CHANGE_ME
# gitops_repo_username: "CHANGE_ME"
# gitops_repo_password: "CHANGE_ME"

# Optional: enable Leantime login through an Authentik OAuth2/OpenID provider.
# Create the Authentik application/provider first, then copy the generated
# client ID and client secret here.
# platform_oidc:
#   leantime:
#     enable: true
#     client_id: "CHANGE_ME"
#     client_secret: "CHANGE_ME"
#     provider_url: "https://auth.thekeepstudios.com/application/o/leantime/"
#     create_user: true
#     default_role: 20
#     scopes: "openid,profile,email"
#     disable_login_form: false

# Optional: enable real SMTP delivery for Leantime invitations and password
# reset emails through Mailgun. Create and verify a Mailgun sending domain first,
# then copy the domain's SMTP credentials here.
# platform_email:
#   leantime:
#     return: "noreply@mg.thekeepstudios.com"
#     use_smtp: true
#     smtp_hosts: "smtp.mailgun.org"
#     smtp_auth: true
#     smtp_username: "postmaster@mg.thekeepstudios.com"
#     smtp_password: "CHANGE_ME_MAILGUN_SMTP_PASSWORD"

# Production validation checks that public HTTPS is available and direct HTTP
# origins are not serving apps. Include the direct origin IP or hostnames for
