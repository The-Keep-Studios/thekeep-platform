# Copy this file to scripts/production.env and update values before running
# scripts/seed-platform-secrets.sh.

# -----------------------------------------------------------------------------
# Core domains (must match ingress hosts in manifests)
# -----------------------------------------------------------------------------
AUTHENTIK_URL=https://auth.thekeepstudios.com
LEANTIME_URL=https://projects.thekeepstudios.com
# GITLAB_URL=https://gitlab.thekeepstudios.com
WISEMAPPING_URL=https://mindmaps.thekeepstudios.com
BASEROW_URL=https://baserow.thekeepstudios.com

# -----------------------------------------------------------------------------
# Monitoring domains
# -----------------------------------------------------------------------------
GRAFANA_HOST=grafana.thekeepstudios.com
PROMETHEUS_HOST=prometheus.thekeepstudios.com
ALERTMANAGER_HOST=alerts.thekeepstudios.com

# -----------------------------------------------------------------------------
# Core platform secrets (required)
# -----------------------------------------------------------------------------
AUTHENTIK_SECRET_KEY=replace-with-long-random-value
AUTHENTIK_POSTGRES_PASSWORD=replace-with-strong-password
AUTHENTIK_BOOTSTRAP_EMAIL=admin@thekeepstudios.com
# IMPORTANT: Authentik reads bootstrap password only on first startup of a fresh DB.
# Changing this later does not rotate/reset the existing admin password.
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-with-strong-password

LEANTIME_DB_ROOT_PASSWORD=replace-with-strong-password
LEANTIME_DB_PASSWORD=replace-with-strong-password

# GITLAB_ROOT_PASSWORD=replace-with-strong-password
# GITLAB_ROOT_EMAIL=root@gitlab.thekeepstudios.com

WISEMAPPING_POSTGRES_PASSWORD=replace-with-strong-password
WISEMAPPING_JWT_SECRET=replace-with-long-random-value
WISEMAPPING_OAUTH_TOKEN_SECRET=replace-with-long-random-value

# -----------------------------------------------------------------------------
# Cloudflare Tunnel edge boundary (required for production GitOps path)
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=replace-with-token

# -----------------------------------------------------------------------------
# Monitoring stack
# -----------------------------------------------------------------------------
MONITORING_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# Leantime OIDC (Authentik provider values)
# Keep local login available during rollout by default.
# Provider slug example: leantime
# Redirect URI in Authentik must be:
#   https://projects.thekeepstudios.com/oidc/callback
# -----------------------------------------------------------------------------
LEAN_OIDC_ENABLE=false
LEAN_OIDC_CLIENT_ID=replace-with-authentik-leantime-client-id
LEAN_OIDC_CLIENT_SECRET=replace-with-authentik-leantime-client-secret
LEAN_OIDC_PROVIDER_URL=https://auth.thekeepstudios.com/application/o/leantime/
LEAN_OIDC_CREATE_USER=true
LEAN_OIDC_DEFAULT_ROLE=20
LEAN_OIDC_SCOPES=openid,profile,email
LEAN_DISABLE_LOGIN_FORM=false

# -----------------------------------------------------------------------------
# GitLab OIDC (Authentik provider values) - DISABLED FOR PILOT
# -----------------------------------------------------------------------------
# OIDC_ENABLED=false
# OIDC_LABEL=Authentik
# OIDC_ISSUER=https://auth.thekeepstudios.com/application/o/gitlab/
# OIDC_UID_FIELD=sub
# OIDC_CLIENT_ID=replace-with-authentik-gitlab-client-id
# OIDC_CLIENT_SECRET=replace-with-authentik-gitlab-client-secret


# -----------------------------------------------------------------------------
# Wisemapping OAuth (configure Authentik app as OAuth/OIDC source here)
# NOTE: Wisemapping OSS currently exposes Google/Facebook/LDAP style auth paths.
# Provider slug example: wisemapping
# Redirect URI in Authentik must be:
#   https://mindmaps.thekeepstudios.com/login/oauth2/code/google
# -----------------------------------------------------------------------------
WISEMAPPING_OAUTH_ENABLED=false
# Leave blank unless WISEMAPPING_OAUTH_ENABLED=true. The scripts set this to oidc automatically when enabled.
WISEMAPPING_SPRING_PROFILES_ACTIVE=
OAUTH_GOOGLE_CLIENT_ID=replace-with-authentik-wisemapping-client-id
OAUTH_GOOGLE_CLIENT_SECRET=replace-with-authentik-wisemapping-client-secret
OAUTH_GOOGLE_ISSUER_URI=https://auth.thekeepstudios.com/application/o/wisemapping/

# -----------------------------------------------------------------------------
# Wisemapping email delivery
# Required when registration email confirmation is enabled.
# Prefer Ansible production_vars.yml for real production configuration.
# -----------------------------------------------------------------------------
WISEMAPPING_MAIL_ENABLED=false
WISEMAPPING_MAIL_SENDER_EMAIL=noreply@mg.thekeepstudios.com
WISEMAPPING_MAIL_HOST=smtp.mailgun.org
WISEMAPPING_MAIL_PORT=587
WISEMAPPING_MAIL_USERNAME=postmaster@mg.thekeepstudios.com
WISEMAPPING_MAIL_PASSWORD=replace-with-mailgun-smtp-password
